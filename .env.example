# Development example env
# 보안: 이 파일을 복사한 .env에는 실제 비밀을 넣되, git에 커밋·채팅/슬랙에 붙여넣지 마세요.
#
# 로컬 API 스모크: Infisical dev에 INTERNAL_SERVICE_TOKEN 등록 후 `infisical run -- npm run dev`
# 통합 E2E(Macro bundle): Infisical 불필요 — `./scripts/e2e-test.sh` (docker-compose.test.yml + LocalStack)
NODE_ENV=development
PORT=3000
# 내부 API (POST /v1/graph-ai/generate 등). E2E/CI 기본값: ci-test-key
# INTERNAL_SERVICE_TOKEN=ci-test-key
# RDB (PostgreSQL - matches prisma schema)
DATABASE_URL=postgresql://user:password@localhost:5432/graphnode
# MongoDB (matches docker-compose.yml)
MONGODB_URL=mongodb://localhost:27018/graphnode

#
REDIS_URL=redisUrl

# AWS Configuration
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# AWS_SESSION_TOKEN=test

# AWS SQS
SQS_REQUEST_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/graph-generation-request-queue
SQS_RESULT_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/graph-generation-result-queue

# AWS S3 (import 첨부는 File Service가 S3_FILE_BUCKET에 upload)
S3_PAYLOAD_BUCKET=graph-node-payloads
S3_FILE_BUCKET=taco5-graphnode-filedata-chat-and-note-s3

# File Service MSA — ECS/Infisical (VPC private, Cloud Map 등)
# FILE_SERVICE_INTERNAL_API_KEY 는 File Service INTERNAL_API_KEY 와 동일
# FILE_SERVICE_BASE_URL 예: http://graphnode-file-service.graphnode.local:3001
FILE_SERVICE_BASE_URL=
FILE_SERVICE_INTERNAL_API_KEY=
FILE_SERVICE_TIMEOUT_MS=300000
# Import finalize async (prod). 미설정 시 finalize API가 동기 처리 (로컬 dev)
# SQS_IMPORT_FINALIZE_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/import-finalize-queue

# Chat export email — direct SMTP (nodemailer). Omit USER+PASS to skip email (export JSON + download still works).
# Gmail: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호. CHAT_EXPORT_SMTP_SECURE는 보통 비우거나 false(587 STARTTLS).
CHAT_EXPORT_SMTP_HOST=smtp.gmail.com
CHAT_EXPORT_SMTP_PORT=587
CHAT_EXPORT_SMTP_SECURE=false
CHAT_EXPORT_SMTP_USER=your-sender@gmail.com
CHAT_EXPORT_SMTP_PASS=your-gmail-app-password
# Optional. Must be a valid email if set (env validation). Otherwise From falls back to CHAT_EXPORT_SMTP_USER.
# CHAT_EXPORT_EMAIL_FROM=your-sender@gmail.com
#
# 로컬에서 실제 메일까지 확인하려면 Infisical에 위 키를 넣고: infisical run -- npm run dev
# SMTP만 빠르게 검증: TEST_LOGIN_SECRET 설정 후 POST /dev/test/email/chat-export-smtp-ping (헤더 x-internal-token 동일 값, body { "to": "..." }).
#
# ZIP이 SMTP 첨부 한도를 넘을 때 링크 전용 메일 본문에 절대 다운로드 URL을 넣으려면 설정(트레일링 슬래시 없음). 미설정 시 jobId·앱 안내만.
# PUBLIC_API_BASE_URL=https://api.example.com

DEV_INSECURE_COOKIES=true

# Dev-only SMTP ping (/dev/test/email/chat-export-smtp-ping). Use a long random string; never commit real secrets.
TEST_LOGIN_SECRET=test-login-secret-for-local-dev-only-min-32chars

SESSION_SECRET = test
# JWT Configuration
JWT_SECRET=test-secret
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

#Google OAuth
OAUTH_GOOGLE_CLIENT_ID=test-test.apps.test.com
OAUTH_GOOGLE_CLIENT_SECRET=test-test
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

#Apple OAuth
OAUTH_APPLE_TEAM_ID=test
OAUTH_APPLE_KEY_ID=test
OAUTH_APPLE_CLIENT_ID=com.test.test.oauth
OAUTH_APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
test
-----END PRIVATE KEY-----"
OAUTH_APPLE_REDIRECT_URI=http://localhost:3000/auth/apple/callback

# Notion Public Integration (OAuth + Webhook) — 미설정 시 /api/auth/notion·/api/webhooks/notion 비활성
# OAUTH_NOTION_CLIENT_ID=
# OAUTH_NOTION_CLIENT_SECRET=
# OAUTH_NOTION_REDIRECT_URI=http://localhost:3000/api/auth/notion/callback
# NOTION_WEBHOOK_VERIFICATION_TOKEN=  # Notion Developer Dashboard → Webhooks 구독 시 1회 수신 값

# AI API Keys (표준 이름: OPENAI_API_KEY — E2E/compose는 OPEN_API_KEY 레거시도 자동 매핑)
OPENAI_API_KEY=sk-placeholder
# OPEN_API_KEY=sk-...  # 구 설정명; e2e-load-env·Jest가 OPENAI_API_KEY로 별칭 처리
# E2E 로컬: placeholder이면 AWS Secrets Manager 조회 (Node SDK 또는 aws CLI + SSO)
# E2E_OPENAI_SECRET_ID=DEV_OPENAI_API_KEY
# E2E_GROQ_SECRET_ID=DEV_GROQ_API_KEY
# --- E2E 테스트 전용 (npm run e2e:test / docker-compose.test.yml). dev·프로덕션에는 넣지 않음 ---
# OpenAI quota(429)로 로컬 full E2E만 Groq 쓸 때:
# E2E_PREFER_GROQ=1
# GROQ_API_KEY=gsk-...
# graphnode-ai는 DEV_GROQ_API_KEY를 우선 사용 — e2e-load-env.sh가 GROQ_API_KEY에서 자동 복사
# (기본 E2E_PREFER_GROQ=0 → OpenAI 사용, .env의 GROQ는 compose/Jest에 전달되지 않음)
# DEEPSEEK_API_KEY=sk-placeholder

# AI Server
AI_SERVER_URI=http://localhost:8000

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# ChromaDB Configuration
CHROMA_API_URL=http://localhost:8000
# CHROMA_API_KEY=your-chroma-token

#Qdrant(Vector DB) - deprecated
# QDRANT_URL=test
# QDRANT_API_KEY=test.test.test
# QDRANT_COLLECTION_NAME=test
# QDRANT_VECTOR_SIZE=1536 # TODO : fixit
# QDRANT_DISTANCE_METRIC=Cosine # TODO : fixit
