# Development example env
# 보안: 이 파일을 복사한 .env에는 실제 비밀을 넣되, git에 커밋·채팅/슬랙에 붙여넣지 마세요.
NODE_ENV=development
PORT=3000
# RDB (PostgreSQL - matches prisma schema)
DATABASE_URL=postgresql://user:password@localhost:5432/graphnode
# MongoDB (matches docker-compose.yml)
MONGODB_URL=mongodb://localhost:27018/graphnode

#
REDIS_URL=redisUrl

# AWS Configuration
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# AWS_SESSION_TOKEN=test

# AWS SQS
SQS_REQUEST_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/graph-generation-request-queue
SQS_RESULT_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/graph-generation-result-queue

# AWS S3
S3_PAYLOAD_BUCKET=graph-node-payloads
S3_FILE_BUCKET=graph-node-files

# Chat export email (SMTP / e.g. Gmail). If USER+PASS unset, export runs but email is skipped.
# Gmail: use an App Password (Google Account → Security), not the normal login password.
CHAT_EXPORT_EMAIL_FROM=your-sender@gmail.com
CHAT_EXPORT_SMTP_HOST=smtp.gmail.com
CHAT_EXPORT_SMTP_PORT=587
# CHAT_EXPORT_SMTP_SECURE=true
CHAT_EXPORT_SMTP_USER=your-sender@gmail.com
CHAT_EXPORT_SMTP_PASS=your-app-password

DEV_INSECURE_COOKIES=true

SESSION_SECRET = test
# JWT Configuration
JWT_SECRET=test-secret
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

#Google OAuth
OAUTH_GOOGLE_CLIENT_ID=test-test.apps.test.com
OAUTH_GOOGLE_CLIENT_SECRET=test-test
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

#Apple OAuth
OAUTH_APPLE_TEAM_ID=test
OAUTH_APPLE_KEY_ID=test
OAUTH_APPLE_CLIENT_ID=com.test.test.oauth
OAUTH_APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
test
-----END PRIVATE KEY-----"
OAUTH_APPLE_REDIRECT_URI=http://localhost:3000/auth/apple/callback


# AI API Keys
OPENAI_API_KEY=sk-placeholder
# DEEPSEEK_API_KEY=sk-placeholder

# AI Server
AI_SERVER_URI=http://localhost:8000

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# ChromaDB Configuration
CHROMA_API_URL=http://localhost:8000
# CHROMA_API_KEY=your-chroma-token

#Qdrant(Vector DB) - deprecated
# QDRANT_URL=test
# QDRANT_API_KEY=test.test.test
# QDRANT_COLLECTION_NAME=test
# QDRANT_VECTOR_SIZE=1536 # TODO : fixit
# QDRANT_DISTANCE_METRIC=Cosine # TODO : fixit
