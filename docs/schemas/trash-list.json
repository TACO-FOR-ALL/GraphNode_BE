{
  "$id": "https://graphnode.dev/schemas/trash-list.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trash List",
  "type": "object",
  "properties": {
    "notes": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "note.json" }
        },
        "nextCursor": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        }
      },
      "required": ["items", "nextCursor"]
    },
    "folders": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "folder.json" }
        },
        "nextCursor": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        }
      },
      "required": ["items", "nextCursor"]
    }
  },
  "required": ["notes", "folders"]
}
