{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StartChatExportResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["jobId", "status"],
  "properties": {
    "jobId": {
      "type": "string",
      "description": "Export job identifier (ULID)"
    },
    "status": {
