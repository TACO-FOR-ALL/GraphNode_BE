{
  "$id": "https://graphnode.dev/schemas/graph-editor-requests.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Graph Editor Request Schemas",
  "description": "Request schemas for direct macro graph editor endpoints.",
  "$defs": {
    "EditorMetadata": {
      "type": "object",
      "description": "Arbitrary editor metadata. Reserved server-managed keys are not allowed.",
      "propertyNames": {
        "not": {
          "enum": ["id", "userId", "createdAt"]
        }
      },
      "additionalProperties": true
    },
    "CreateNodeEditorDto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "clusterId"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "summary": {
          "type": "string",
          "maxLength": 2000
        },
        "clusterId": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "$ref": "#/$defs/EditorMetadata"
        },
        "sourceType": {
          "type": "string",
          "enum": ["chat", "markdown", "notion"]
        },
        "timestamp": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "numMessages": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "UpdateNodeEditorDto": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "summary": {
          "type": "string",
          "maxLength": 2000
        },
        "metadata": {
          "$ref": "#/$defs/EditorMetadata"
        },
        "sourceType": {
          "type": "string",
          "enum": ["chat", "markdown", "notion"]
        },
        "timestamp": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "numMessages": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "CreateEdgeEditorDto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target"],
      "properties": {
        "source": {
          "type": "integer",
          "minimum": 1
        },
        "target": {
          "type": "integer",
          "minimum": 1
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "relationType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "User-facing relation type. The backend normalizes this value to UPPER_SNAKE_CASE."
        },
        "relation": {
          "type": "string",
          "maxLength": 200
        },
        "properties": {
          "$ref": "#/$defs/EditorMetadata"
        }
      }
    },
    "UpdateEdgeEditorDto": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "relationType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "User-facing relation type. The backend normalizes this value to UPPER_SNAKE_CASE."
        },
        "relation": {
          "type": "string",
          "maxLength": 200
        },
        "properties": {
          "$ref": "#/$defs/EditorMetadata"
        }
      }
    },
    "CreateClusterEditorDto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Optional client-supplied cluster ID. If omitted, the backend generates a UUID."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "description": {
          "type": "string",
          "maxLength": 2000
        },
        "themes": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "string",
            "maxLength": 100
          }
        }
      }
    },
    "UpdateClusterEditorDto": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "description": {
          "type": "string",
          "maxLength": 2000
        },
        "themes": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "string",
            "maxLength": 100
          }
        }
      }
    },
    "CreateSubclusterEditorDto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clusterId"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Optional client-supplied subcluster ID. If omitted, the backend generates a UUID."
        },
        "clusterId": {
          "type": "string",
          "minLength": 1
        },
        "topKeywords": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "maxLength": 100
          }
        },
        "density": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "UpdateSubclusterEditorDto": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "topKeywords": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "maxLength": 100
          }
        },
        "density": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "MoveNodeToClusterDto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["newClusterId"],
      "properties": {
        "newClusterId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "MoveSubclusterToClusterDto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["newClusterId"],
      "properties": {
        "newClusterId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "AddNodeToSubclusterDto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeId"],
      "properties": {
        "nodeId": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "CreateNodeOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "payload"],
      "properties": {
        "type": { "const": "createNode" },
        "payload": { "$ref": "#/$defs/CreateNodeEditorDto" }
      }
    },
    "UpdateNodeOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "nodeId", "payload"],
      "properties": {
        "type": { "const": "updateNode" },
        "nodeId": { "type": "integer", "minimum": 1 },
        "payload": { "$ref": "#/$defs/UpdateNodeEditorDto" }
      }
    },
    "DeleteNodeOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "nodeId"],
      "properties": {
        "type": { "const": "deleteNode" },
        "nodeId": { "type": "integer", "minimum": 1 },
        "permanent": { "type": "boolean", "default": false }
      }
    },
    "CreateEdgeOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "payload"],
      "properties": {
        "type": { "const": "createEdge" },
        "payload": { "$ref": "#/$defs/CreateEdgeEditorDto" }
      }
    },
    "UpdateEdgeOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "edgeId", "payload"],
      "properties": {
        "type": { "const": "updateEdge" },
        "edgeId": { "type": "string", "minLength": 1 },
        "payload": { "$ref": "#/$defs/UpdateEdgeEditorDto" }
      }
    },
    "DeleteEdgeOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "edgeId"],
      "properties": {
        "type": { "const": "deleteEdge" },
        "edgeId": { "type": "string", "minLength": 1 },
        "permanent": { "type": "boolean", "default": false }
      }
    },
    "CreateClusterOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "payload"],
      "properties": {
        "type": { "const": "createCluster" },
        "payload": { "$ref": "#/$defs/CreateClusterEditorDto" }
      }
    },
    "UpdateClusterOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "clusterId", "payload"],
      "properties": {
        "type": { "const": "updateCluster" },
        "clusterId": { "type": "string", "minLength": 1 },
        "payload": { "$ref": "#/$defs/UpdateClusterEditorDto" }
      }
    },
    "DeleteClusterOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "clusterId"],
      "properties": {
        "type": { "const": "deleteCluster" },
        "clusterId": { "type": "string", "minLength": 1 },
        "cascade": { "type": "boolean", "default": false },
        "permanent": { "type": "boolean", "default": false }
      }
    },
    "CreateSubclusterOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "payload"],
      "properties": {
        "type": { "const": "createSubcluster" },
        "payload": { "$ref": "#/$defs/CreateSubclusterEditorDto" }
      }
    },
    "UpdateSubclusterOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "subclusterId", "payload"],
      "properties": {
        "type": { "const": "updateSubcluster" },
        "subclusterId": { "type": "string", "minLength": 1 },
        "payload": { "$ref": "#/$defs/UpdateSubclusterEditorDto" }
      }
    },
    "DeleteSubclusterOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "subclusterId"],
      "properties": {
        "type": { "const": "deleteSubcluster" },
        "subclusterId": { "type": "string", "minLength": 1 },
        "permanent": { "type": "boolean", "default": false }
      }
    },
    "MoveNodeToClusterOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "nodeId", "newClusterId"],
      "properties": {
        "type": { "const": "moveNodeToCluster" },
        "nodeId": { "type": "integer", "minimum": 1 },
        "newClusterId": { "type": "string", "minLength": 1 }
      }
    },
    "MoveSubclusterToClusterOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "subclusterId", "newClusterId"],
      "properties": {
        "type": { "const": "moveSubclusterToCluster" },
        "subclusterId": { "type": "string", "minLength": 1 },
        "newClusterId": { "type": "string", "minLength": 1 }
      }
    },
    "AddNodeToSubclusterOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "subclusterId", "nodeId"],
      "properties": {
        "type": { "const": "addNodeToSubcluster" },
        "subclusterId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "integer", "minimum": 1 }
      }
    },
    "RemoveNodeFromSubclusterOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "subclusterId", "nodeId"],
      "properties": {
        "type": { "const": "removeNodeFromSubcluster" },
        "subclusterId": { "type": "string", "minLength": 1 },
        "nodeId": { "type": "integer", "minimum": 1 }
      }
    },
    "EditorBatchOperation": {
      "description": "Discriminated union of graph editor batch operations. The `type` field selects the required operation shape.",
      "oneOf": [
        { "$ref": "#/$defs/CreateNodeOperation" },
        { "$ref": "#/$defs/UpdateNodeOperation" },
        { "$ref": "#/$defs/DeleteNodeOperation" },
        { "$ref": "#/$defs/CreateEdgeOperation" },
        { "$ref": "#/$defs/UpdateEdgeOperation" },
        { "$ref": "#/$defs/DeleteEdgeOperation" },
        { "$ref": "#/$defs/CreateClusterOperation" },
        { "$ref": "#/$defs/UpdateClusterOperation" },
        { "$ref": "#/$defs/DeleteClusterOperation" },
        { "$ref": "#/$defs/CreateSubclusterOperation" },
        { "$ref": "#/$defs/UpdateSubclusterOperation" },
        { "$ref": "#/$defs/DeleteSubclusterOperation" },
        { "$ref": "#/$defs/MoveNodeToClusterOperation" },
        { "$ref": "#/$defs/MoveSubclusterToClusterOperation" },
        { "$ref": "#/$defs/AddNodeToSubclusterOperation" },
        { "$ref": "#/$defs/RemoveNodeFromSubclusterOperation" }
      ],
      "discriminator": {
        "propertyName": "type"
      }
    },
    "BatchEditorRequestDto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operations"],
      "properties": {
        "operations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": {
            "$ref": "#/$defs/EditorBatchOperation"
          }
        }
      }
    }
  }
}
